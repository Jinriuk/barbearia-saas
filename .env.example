# Copie para .env.local e preencha com os valores do seu projeto Supabase.
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

# Obrigatórias
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# URL pública da aplicação (usada nos redirects de auth quando não há header origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Domínio raiz para subdomínios white label (ex.: nexobarber.com.br).
# Quando definido, cada barbearia responde em https://SLUG.dominio.
# Requer domínio wildcard (*.dominio) apontado para a Vercel.
# NEXT_PUBLIC_ROOT_DOMAIN=

# Somente server-side, NUNCA exponha no navegador. Necessária apenas para rotinas admin.
# SUPABASE_SERVICE_ROLE_KEY=

# Necessária apenas quando o billing/webhook de pagamentos for ativado.
# PAYMENTS_WEBHOOK_SECRET=
